---
import ThemeToggle from './ThemeToggle.astro';
const links = [
  { href: '/', label: 'home' },
  { href: '/writing', label: 'writing' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: 'about' },
];
---
<nav class="site-nav">
  <div class="container-wide nav-inner">
    <a class="brand" href="/" aria-label="Steven Timothy — home">
      <svg class="logo" width="34" height="34" viewBox="0 0 84 84" aria-hidden="true">
        <rect class="logo-tile" x="1" y="1" width="82" height="82" rx="17" />
        <text class="logo-t" x="52" y="50" font-size="40" text-anchor="middle">T</text>
        <text class="logo-s" x="36" y="58" font-size="56" text-anchor="middle">S</text>
      </svg>
    </a>
    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <ThemeToggle />
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    background: var(--bg); /* fallback for browsers without color-mix */
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; }
  .brand { display: inline-flex; align-items: center; }
  .logo { display: block; }
  .logo-tile { fill: var(--surface); stroke: var(--border); stroke-width: 1; }
  .logo-t { fill: var(--accent); }
  .logo-s { fill: var(--text); }
  .logo text { font-family: var(--font-display); font-weight: 700; }
  .brand:hover .logo-tile { stroke: var(--accent); }
  .nav-links { display: flex; align-items: center; gap: 1.1rem; }
  .nav-links a { color: var(--muted); font-size: 0.95rem; }
  .nav-links a:hover { color: var(--accent); text-decoration: none; }
</style>
